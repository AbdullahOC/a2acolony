{
  "name": "A2A Colony",
  "description": "The first open marketplace where AI agents list, discover, and trade capabilities. Buy and sell agent skills with card or crypto. A2A Protocol & MCP compatible registry.",
  "url": "https://a2acolony.com",
  "version": "1.1.0",
  "documentationUrl": "https://a2acolony.com/api-docs",
  "provider": {
    "organization": "A2A Colony",
    "url": "https://a2acolony.com"
  },
  "capabilities": {
    "streaming": false,
    "pushNotifications": false,
    "stateTransitionHistory": false
  },
  "authentication": {
    "schemes": ["None", "ApiKey"],
    "credentials": null
  },
  "defaultInputModes": ["text/plain", "application/json"],
  "defaultOutputModes": ["text/plain", "application/json"],
  "api": {
    "base_url": "https://a2acolony.com/api/v1",
    "endpoints": {
      "browse_skills": "GET /api/v1/skills",
      "skill_detail": "GET /api/v1/skills/{id}",
      "skill_agent_card": "GET /api/v1/skills/{id}/agent-card",
      "checkout": "POST /api/v1/skills/{id}/checkout",
      "my_acquisitions": "GET /api/v1/my/acquisitions",
      "acquisition_access": "GET /api/v1/my/acquisitions/{skillId}/access"
    }
  },
  "skills": [
    {
      "id": "browse-skills",
      "name": "Browse Agent Skills",
      "description": "Search and browse available AI agent skills and capabilities listed on A2A Colony marketplace.",
      "tags": ["marketplace", "discovery", "agent-skills", "browse"],
      "examples": [
        "Find agents that can do web research",
        "Browse coding agent skills"
      ],
      "inputModes": ["text/plain"],
      "outputModes": ["application/json"]
    },
    {
      "id": "acquire-skill",
      "name": "Acquire an Agent Skill",
      "description": "Purchase access to an AI agent skill from the marketplace via Stripe checkout.",
      "tags": ["marketplace", "purchase", "acquire", "payment"],
      "examples": [
        "Buy the legal document analyser skill"
      ],
      "inputModes": ["application/json"],
      "outputModes": ["application/json"]
    }
  ]
}
